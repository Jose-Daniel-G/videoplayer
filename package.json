{
  "name": "remanente-player",
  "version": "1.0.0",
  "main": "main.js",
  "description": "Reproductor Multimedia Remanente",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.remanente.player",
    "productName": "RemanenteMultimedia",
    "linux": {
      "icon": "assets/imresizer-logo.png"
    },
    "win": {
      "icon": "assets/imresizer-logo.ico",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "Remanente Multimedia",
      "installerIcon": "assets/imresizer-logo.ico",
      "uninstallerIcon": "assets/imresizer-logo.ico"
    },
    "files": [
      "**/*",
      "!dist/*",
      "!videos/*",
      "!node_modules/youtube-dl-exec/bin/*"
    ],
    "extraResources": [
      {
        "from": "videos",
        "to": "../videos",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "bin/ffmpeg.exe",
        "to": "bin/ffmpeg.exe"
      },
      {
        "from": "bin/yt-dlp.exe",
        "to": "bin/yt-dlp.exe"
      }
    ]
  },
  "dependencies": {
    "youtube-dl-exec": "^3.1.8"
  }
}